// Paths for where we build the dev (development) and prod (production)
// versions of Sitrec.
//
// The build folder is derived from the current git branch so that each
// worktree automatically builds to its own directory:
//   main          → dist/sitrec
//   feature/foo   → dist/build-feature-foo
//
// Override buildFolder below if you want a fixed output location.

const { execSync } = require('child_process');
const path = require('path');

let branch;
try {
    branch = execSync('git rev-parse --abbrev-ref HEAD', { encoding: 'utf-8' }).trim();
} catch {
    branch = 'main';
}

// main (and detached HEAD) → 'sitrec', everything else → 'build-<branch-slug>'
let buildFolder;
if (branch === 'main' || branch === 'HEAD') {
    buildFolder = 'sitrec';
} else {
    buildFolder = 'build-' + branch.replace(/\//g, '-');
}

module.exports = {
    dev_path: path.resolve(__dirname, '..', 'dist', buildFolder),
    prod_path: path.resolve(__dirname, '..', 'dist', buildFolder),
    buildFolder: buildFolder,
}
