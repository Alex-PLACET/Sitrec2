{
  "name": "sitrec-video-viewer",
  "version": "1.0.0",
  "description": "Sitrec Desktop - Offline serverless Electron app",
  "main": "main.js",
  "author": "Metabunk",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "node ../../scripts/runDesktopBuilder.js --platform mac --target dmg --arch arm64 --output staging",
    "build-direct": "node ../../scripts/runDesktopBuilder.js --platform mac --target dmg --arch arm64 --output final",
    "build-universal": "node ../../scripts/runDesktopBuilder.js --platform mac --target dmg --arch universal --output final",
    "build-local": "npm run build",
    "build-local-nosign": "node ../../scripts/runDesktopBuilder.js --platform mac --target dmg --arch arm64 --output staging --no-sign",
    "build-dir-local-nosign": "node ../../scripts/runDesktopBuilder.js --platform mac --target dir --arch arm64 --output staging --no-sign",
    "build-win": "node ../../scripts/runDesktopBuilder.js --platform win --target nsis --arch x64 --output staging",
    "build-win-direct": "node ../../scripts/runDesktopBuilder.js --platform win --target nsis --arch x64 --output final"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.metabunk.sitrec-desktop",
    "productName": "Sitrec",
    "directories": {
      "output": "../../apps_dist"
    },
    "files": [
      "desktopStateStore.js",
      "main.js",
      "preload.js",
      "server.js"
    ],
    "extraResources": [
      {
        "from": "../../dist-serverless",
        "to": "dist-serverless",
        "filter": [
          "**/*",
          "!**/.DS_Store"
        ]
      },
      {
        "from": "../../../sitrec-terrain",
        "to": "sitrec-terrain",
        "filter": [
          "**/*",
          "!**/.DS_Store"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "category": "public.app-category.utilities",
      "signIgnore": [
        "/Contents/Resources/sitrec-terrain($|/)",
        "/Contents/Resources/dist-serverless/docs($|/)",
        "/Contents/Resources/dist-serverless/tools($|/)",
        "/Contents/Resources/dist-serverless/.*\\.(?:md|html|txt|json)$"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "oneClick": false,
      "perMachine": false
    },
    "dmg": {
      "size": "4g",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "asar": true,
    "compression": "maximum"
  }
}
