{
  "manifest_version": 3,
  "name": "SitrecBridge",
  "version": "1.0.39",
  "description": "MCP bridge connecting AI assistants to a running Sitrec instance",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://local.metabunk.org/*",
    "https://www.metabunk.org/sitrec*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://local.metabunk.org/*",
        "https://www.metabunk.org/sitrec*",
        "http://localhost:*/*",
        "http://127.0.0.1:*/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js"],
      "matches": [
        "https://local.metabunk.org/*",
        "https://www.metabunk.org/*",
        "http://localhost:*/*",
        "http://127.0.0.1:*/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SitrecBridge"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
